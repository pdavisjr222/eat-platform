# E.A.T. Platform — Root Environment Variables
# ==============================================
# This file documents all environment variables used across the platform.
# Each package also has its own .env.example with more detail.
#
# For local dev: copy packages/server/.env.example → packages/server/.env
#                copy packages/web/.env.example    → packages/web/.env
#                copy packages/mobile/.env.example → packages/mobile/.env

# ── Server ──────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
DOMAIN=https://projecteat.org

# ── Database ────────────────────────────────────
# Production PostgreSQL (Railway + Neon) — required in production:
DATABASE_URL=postgresql://user:password@host:5432/eat_platform
# Local SQLite fallback (only used when DATABASE_URL is NOT set):
DATABASE_PATH=./db.sqlite

# ── Auth ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ── Email — Resend ───────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@projecteat.org

# ── Payments — Stripe ────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Video — Agora (https://console.agora.io) ─────
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# ── Push — Firebase (https://console.firebase.google.com) ─
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── Caching — Redis ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Maps — Google ────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── File Uploads ─────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Web (Vite) ───────────────────────────────────
VITE_API_URL=http://localhost:5000

# ── Mobile (Expo) ────────────────────────────────
# iOS Simulator:    http://localhost:5000
# Android Emulator: http://10.0.2.2:5000
# Physical device:  http://<your-local-ip>:5000
# Production:       https://api.eat-platform.railway.app
EXPO_PUBLIC_API_URL=http://localhost:5000
