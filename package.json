{
  "name": "eat-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "mobile": "npm run dev --workspace=packages/mobile",
    "web": "npm run dev --workspace=packages/web",
    "server": "npm run dev --workspace=packages/server"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "playwright": "^1.58.2",
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
