# E.A.T. Platform — Server Environment Variables
# =================================================
# Copy this file to .env and fill in your values
# Required in production = ✅   Optional / has default = ⚙️

# ── Server ──────────────────────────────────────
NODE_ENV=development                                # ✅
PORT=5000                                           # ⚙️ default: 5000
APP_URL=http://localhost:5000                       # ✅ used in email links
DOMAIN=https://projecteat.org                      # ✅ used in CORS + email

# ── Database ────────────────────────────────────
# PostgreSQL (production — Railway / Neon)
DATABASE_URL=postgresql://user:password@host:5432/eat_platform  # ✅ required in production
# SQLite (local development — only used when DATABASE_URL is NOT set)
DATABASE_PATH=./db.sqlite                          # ⚙️ default: ./db.sqlite

# ── Auth ────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-change-in-production  # ✅

# ── Email — Resend (https://resend.com) ─────────
RESEND_API_KEY=re_your_resend_api_key               # ✅
EMAIL_FROM=noreply@projecteat.org                  # ⚙️ default: noreply@projecteat.org

# ── Payments — Stripe (https://dashboard.stripe.com) ─
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key   # ✅
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key # ⚙️ frontend reference only
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret    # ✅ required in production

# ── Video — Agora (https://console.agora.io) ────
AGORA_APP_ID=your_agora_app_id                     # ✅
AGORA_APP_CERTIFICATE=your_agora_app_certificate   # ✅

# ── Push Notifications — Firebase (https://console.firebase.google.com) ─
FIREBASE_PROJECT_ID=your-firebase-project-id       # ✅
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour key here\n-----END PRIVATE KEY-----\n"  # ✅
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com  # ✅

# ── Caching — Redis ──────────────────────────────
REDIS_URL=redis://localhost:6379                   # ⚙️ app works without Redis (in-memory fallback)

# ── Maps — Google (https://console.cloud.google.com) ─
GOOGLE_MAPS_API_KEY=your_google_maps_api_key       # ✅

# ── File Uploads ─────────────────────────────────
UPLOAD_DIR=./uploads                               # ⚙️ default: ./uploads
MAX_FILE_SIZE=10485760                             # ⚙️ default: 10MB

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000                        # ⚙️ default: 15 minutes
RATE_LIMIT_MAX_REQUESTS=100                        # ⚙️ default: 100 req/window
