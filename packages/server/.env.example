# Database
DATABASE_URL=postgresql://user:password@host:5432/eat_platform
# Or use SQLite for development: file:./db.sqlite

# Authentication
JWT_SECRET=your-256-bit-secret-key-change-this-in-production

# Agora Video (https://console.agora.io)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# Firebase Cloud Messaging (https://console.firebase.google.com)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Stripe Payments (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Email Service (https://resend.com - optional)
RESEND_API_KEY=re_your_resend_api_key

# Redis (optional for production)
REDIS_URL=redis://localhost:6379

# Google Maps API (https://console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Server Configuration
PORT=5000
NODE_ENV=development
