{
  "expo": {
    "name": "E.A.T. Platform",
    "slug": "eat-platform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "eat",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#22c55e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "org.projecteat.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby foraging spots and marketplace listings.",
        "NSLocationAlwaysUsageDescription": "We need your location to show nearby foraging spots and marketplace listings.",
        "NSCameraUsageDescription": "Upload photos of your listings and foraging spots.",
        "NSPhotoLibraryUsageDescription": "Choose photos from your library to share.",
        "NSPhotoLibraryAddUsageDescription": "Save photos to your library.",
        "NSMicrophoneUsageDescription": "Enable audio for video calls with community members."
      }
    },
    "android": {
      "package": "org.projecteat.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22c55e",
          "sounds": [
            "./assets/notification_sound.wav"
          ]
        }
      ],
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a7ef1c7f-cca4-46b5-a0f3-8cd5afc4258a"
      }
    },
    "owner": "pdavisjr22"
  }
}
